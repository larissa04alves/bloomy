{
  "name": "@bloomy/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@bloomy/env": "workspace:*",
    "@libsql/client": "catalog:",
    "csv-parse": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "libsql": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bloomy/config": "workspace:*",
    "@types/bun": "^1.2.23",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
