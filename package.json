{
  "name": "bloomy",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@libsql/client": "0.17.4",
      "libsql": "0.5.29",
      "better-auth": "1.6.23",
      "@tailwindcss/postcss": "^4.3.2",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @bloomy/db",
    "db:studio": "turbo run db:studio -F @bloomy/db",
    "db:generate": "turbo run db:generate -F @bloomy/db",
    "db:migrate": "turbo run db:migrate -F @bloomy/db",
    "db:local": "turbo run db:local -F @bloomy/db",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry"
  },
  "dependencies": {
    "@bloomy/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bloomy/config": "workspace:*",
    "@types/node": "^22.13.14",
    "tsx": "^4.22.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "vercel": "^54.18.6"
  },
  "packageManager": "bun@1.3.14"
}
